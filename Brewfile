# Software referenced by configs in this repo.
# Install / refresh with:  brew bundle --file=Brewfile
#
# Already-installed apps (manual .dmg installs) are not re-installed by brew;
# brew bundle just records them as satisfied. New machines pick everything up.

# --- Casks (GUI apps) ---
cask "iterm2"
cask "ghostty"
cask "cmux"

# --- Formulae (CLIs / language runtimes) ---
# All unpinned — `brew "x"` tracks the current stable release. If you need a
# specific version for a project, use mise/asdf/nvm/pyenv at the project
# level rather than pinning here.
brew "node"          # for Claude Code (`npm i -g @anthropic-ai/claude-code`)
brew "python"        # latest stable CPython 3.x
brew "go"            # latest stable Go
brew "git"
brew "jq"
